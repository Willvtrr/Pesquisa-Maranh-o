rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a role-based access control model for the 'Maranhão Insights' application.
     * It prioritizes a clear separation between administrative data management and public/authenticated
     * data consumption. In this prototyping phase, rules focus on strict authorization (who can access)
     * while maintaining flexibility regarding the specific fields of the data records.
     *
     * DATA STRUCTURE
     * - /survey_records/{id}: Central repository for survey response data.
     * - /roles_admin/{userId}: A Database Access Control (DBAC) collection where the existence 
     *   of a user's UID as a document ID grants administrative privileges.
     *
     * KEY SECURITY DECISIONS
     * - Authentication: All data access requires a verified identity (isSignedIn).
     * - Admin Privileges: Write access to the master survey data is strictly restricted to users
     *   verified against the /roles_admin collection.
     * - Data Integrity: Relational consistency is enforced by ensuring the internal 'id' of a
     *   SurveyRecord matches its document path and remains immutable.
     * - Read Access: Survey records are listable by any authenticated user to support the
     *   application's client-side aggregation and filtering requirements.
     */

    // --- Global Helper Functions ---

    /**
     * @description Checks if the request is made by a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges by 
     * verifying their existence in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the SurveyRecord collection, representing master survey data.
     * @path /survey_records/{surveyRecordId}
     * @allow get, list: If the user is signed in (supports client-side analysis).
     * @allow create: If the user is signed in (allowed for seeding/prototyping phase).
     * @allow update, delete: If the user is a verified administrator.
     * @principle Role-based access control and relational integrity validation.
     */
    match /survey_records/{surveyRecordId} {
      allow get, list: if isSignedIn();
      
      // Allow creation for authenticated users to enable seeding in prototype
      // Integrity check ensures the internal ID matches the document path
      allow create: if isSignedIn() && string(request.resource.data.id) == surveyRecordId;
      
      allow update: if isAdmin() && resource != null && request.resource.data.id == resource.data.id;
      
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for the admin roles collection used for access control.
     * @path /roles_admin/{userId}
     * @allow get: Any signed-in user can check their own admin status.
     * @allow list: Only existing admins can list the directory of administrators.
     * @deny create, update, delete: Role management is restricted to server-side/console operations.
     * @principle Database Access Control (DBAC) using existence-over-content.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    // Default deny for any paths not explicitly matched
    match /{path=**} {
      allow read, write: if false;
    }
  }
}