rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MARANHÃO INSIGHTS - SECURITY ARCHITECTURE
     *
     * Liberando leitura pública para o Dashboard e restringindo escrita 
     * para usuários autenticados (Importação Massiva).
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /candidates/{candidateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Permite leitura pública (Dashboard).
     * Escrita e limpeza exigem autenticação.
     */
    match /surveyResponses/{surveyResponseId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /candidateRatings/{candidateRatingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

  }
}