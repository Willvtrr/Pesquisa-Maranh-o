rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MARANHÃO INSIGHTS - SECURITY ARCHITECTURE
     *
     * Liberando acesso de escrita para usuários autenticados na coleção surveyResponses
     * para permitir a carga massiva de dados (109k registros).
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /candidates/{candidateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Permite que usuários autenticados (incluindo anônimos) criem e deletem registros.
     * Necessário para o fluxo de importação e limpeza de dados.
     */
    match /surveyResponses/{surveyResponseId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /candidateRatings/{candidateRatingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

  }
}