rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MARANHÃO INSIGHTS - SECURITY ARCHITECTURE
     *
     * Regras otimizadas para Dashboard Público e Importação Privada.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Permite leitura pública (Dashboard e Auditoria).
     * Escrita (Importação) e Deleção (Limpeza) exigem que o usuário esteja autenticado.
     */
    match /surveyResponses/{surveyResponseId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Regras genéricas para outras coleções (Admin)
    match /roles_admin/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /candidates/{candidateId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /candidateRatings/{candidateRatingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

  }
}