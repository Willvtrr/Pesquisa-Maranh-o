
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MARANHÃO INSIGHTS - SECURITY RULES
     *
     * Core Philosophy:
     * 1. Public Read: Geographical data and survey responses are publicly readable
     *    to drive the dashboard and map for all users.
     * 2. Protected Write: Writing to surveyResponses (import/clear) requires
     *    authentication to ensure data integrity.
     */

    match /mesorregioes/{mesorregiaoId} {
      allow get, list: if true;
      allow write: if false; // Only manageable via Admin SDK/Console
    }

    match /cidades/{cidadeId} {
      allow get, list: if true;
      allow write: if false; // Only manageable via Admin SDK/Console
    }

    match /surveyResponses/{responseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
