
{
  "entities": {
    "SurveyResponse": {
      "title": "SurveyResponse",
      "description": "Individual survey response record for high-volume analysis.",
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "region": { "type": "string" },
        "gender": { "type": "string" },
        "age": { "type": "string" },
        "approval_gov": { "type": "string" },
        "vote_president": { "type": "string" },
        "problem_grave": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "surveyResponses/{responseId}": {
      "schema": "#/entities/SurveyResponse",
      "description": "Collection for all survey records (100k+ lines)."
    }
  }
}
